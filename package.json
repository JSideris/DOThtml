{
  "name": "dothtml",
  "version": "6.0.0-beta.47",
  "description": "DOThtml is a client-side web building framework written in TypeScript.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "unpkg": "./dist/index.global.js",
  "jsdelivr": "./dist/index.global.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "test": "npm run build && jest",
    "build": "tsup",
    "benchmarks": "npm run build && cd benchmarks && npm run bench",
    "size": "size-limit",
    "publish-beta": "npm run build && npm run size && npm publish --tag beta",
    "prepublishOnly": "npm run build && npm run size"
  },
  "size-limit": [
    {
      "path": "dist/index.global.js",
      "limit": "20 KB"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/JSideris/DOThtml.git"
  },
  "keywords": [
    "html",
    "page",
    "dynamic",
    "javascript",
    "typescript",
    "web",
    "builder",
    "generation",
    "component",
    "framework",
    "spa"
  ],
  "author": "Joshua Sideris",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/JSideris/DOThtml/issues"
  },
  "homepage": "https://dothtml.org/",
  "devDependencies": {
    "@babel/preset-env": "^7.14.5",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@swc/core": "^1.15.33",
    "@testing-library/jest-dom": "^5.13.0",
    "@types/jest": "^29.5.11",
    "@types/node": "^18.14.2",
    "copyfiles": "^2.4.1",
    "esm": "^3.2.25",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "size-limit": "^12.1.0",
    "ts-jest": "^29.0.5",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.1",
    "tsup": "^8.5.1",
    "typescript": "^5.0.2",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "dothtml-interfaces": "file:../DOThtml-interfaces"
  }
}
