{
  "name": "dothtml-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "dothtml.org",
    "benchmarks"
  ],
  "scripts": {
    "build": "npm run build -w dothtml && npm run build -w create-dothtml",
    "test": "npm test -w dothtml",
    "dev": "npm run dev -w dothtml.org",
    "benchmarks": "npm run benchmarks -w dothtml",
    "version-packages": "changeset version",
    "release": "npm run build && changeset publish",
    "release-all": "node tools/smart-release.js"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "jest": "^29.7.0",
    "tsup": "^8.5.1",
    "typescript": "^5.0.2"
  }
}
